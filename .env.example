# Optional. If set, /api/chat uses this key and the client never needs to send one.
# Leave unset to let students paste their own key in the header UI.
OPENAI_API_KEY=

# Optional GitLab token used as a fallback when /api/gitlab is called without one.
# Leave unset for public repos or when the client supplies a token per-request.
GITLAB_TOKEN=

# Server port (default 3000)
PORT=3000
